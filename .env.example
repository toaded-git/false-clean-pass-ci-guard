# false-clean-pass-ci-guard — 환경변수 예시 (값 없이 키 이름만)
#
# 이 Action 자체는 상태 없는 정적 검사기라 별도 시크릿이 필요 없다.
# GITHUB_TOKEN 은 GitHub Actions 가 자동 주입한다 (수동 발급 불필요).
#
# 아래는 로컬 개발/테스트(CLI 모드) 시에만 사용.

# GitHub API 호출(diff, Check Run, PR 코멘트) 로컬 테스트용 토큰
GITHUB_TOKEN=

# 대상 저장소 (owner/repo) — 로컬 CLI 재현 실행 시
GITHUB_REPOSITORY=
